.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the Python version is usually managed by the user.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, lock files are meant to be committed.
#   However, if you feel strongly about it, feel free to uncomment the following line:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is meant to be committed.
#   uncomment the following line if you want to ignore it.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is meant to be committed.
#   uncomment the following line if you want to ignore it.
#pdm.lock

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

